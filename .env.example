# --- Supabase Postgres ---
# Transaction pooler (port 6543) for the app at runtime. Append the pgbouncer flags.
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct/session connection (port 5432) used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# --- Google OAuth (own code flow) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# --- Secrets ---
# Both are base64-encoded 32 random bytes: `openssl rand -base64 32`
TOKEN_ENC_KEY=""
SESSION_SECRET=""

# --- App ---
APP_URL="http://localhost:3000"

# --- LLM ---  (model IDs live here, not in code — confirm current IDs in provider docs)
LLM_PROVIDER="anthropic"            # anthropic | openai
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_MODEL="gpt-4o-mini"
