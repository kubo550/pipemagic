// PipeMagic — Phase 1 schema.
// Only the foundation entities live here. Deal/Company/Stakeholder/Meeting/Fact
// and the rest of PRD §9 arrive in Phase 2+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for the app at runtime.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used by `prisma migrate` / introspection.
  directUrl = env("DIRECT_URL")
}

// A PipeMagic user. Keyed to the Google account `sub` (stable id), NOT to
// Supabase Auth. Everything in the product FKs to this table (PRD §6/§9).
model User {
  id        String   @id @default(cuid())
  googleSub String   @unique
  email     String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tokens       OAuthToken[]
  companies    Company[]
  deals        Deal[]
  stakeholders Stakeholder[]
  meetings     Meeting[]
  facts        Fact[]
  profile      UserProfile?
  runs         Run[]
}

// History of agent-loop executions (PRD §9). One row per chat run: the request,
// how it ended, what it cost, and the result — so runs are visible/traceable.
model Run {
  id         String   @id @default(cuid())
  userId     String
  request    String
  status     String
  provider   String
  model      String
  iterations Int      @default(0)
  costUsd    Float    @default(0)
  resultText String   @default("")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// The user's own "about me" — free text folded into the agent system prompt so
// the assistant adapts to whoever they are (salesperson, job candidate,
// consultant, …). Generic on purpose, not sales-only. One per user.
model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  aboutMe   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// OAuth tokens for an external provider. All token material is stored as
// ciphertext (AES-256-GCM) — plaintext never touches the database (PRD §8).
model OAuthToken {
  id              String   @id @default(cuid())
  userId          String
  provider        String // "google"
  accessTokenEnc  String
  refreshTokenEnc String
  expiresAt       DateTime
  scope           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// --- Context model (knowledge store, PRD §5.2) ---
// All entities are keyed to userId; authorization is enforced in code by always
// filtering on userId (Prisma + Supabase RLS don't compose — PRD §6).

model Company {
  id        String   @id @default(cuid())
  userId    String
  name      String
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals        Deal[]
  stakeholders Stakeholder[]

  @@index([userId])
}

model Deal {
  id        String   @id @default(cuid())
  userId    String
  companyId String?
  name      String
  stage     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  stakeholders Stakeholder[]
  meetings     Meeting[]
  facts        Fact[]

  @@index([userId])
  @@index([companyId])
}

model Stakeholder {
  id        String   @id @default(cuid())
  userId    String
  dealId    String?
  companyId String?
  name      String
  email     String?
  role      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dealId])
}

model Meeting {
  id              String    @id @default(cuid())
  userId          String
  dealId          String?
  externalEventId String?
  title           String?
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)
  facts Fact[]

  @@index([userId])
  @@index([dealId])
}

// Where a Fact came from — drives grounding (cite the source) and the split
// between trusted (calendar/crm) and to-verify (web) facts (PRD §5.2).
enum SourceType {
  calendar
  crm
  transcript
  web
}

// The backbone of the context model: an atomic, addressed, sourced claim.
// Always tied to a user; optionally anchored to a Meeting (generic) and/or a
// Deal (sales). Generic on purpose — not every user has "deals".
// `supersededById` lets newer facts retire older ones without deletion.
model Fact {
  id             String     @id @default(cuid())
  userId         String
  dealId         String?
  meetingId      String?
  text           String
  sourceType     SourceType
  sourceRef      String?
  confidence     Float      @default(1.0)
  observedAt     DateTime   @default(now())
  supersededById String?
  createdAt      DateTime   @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal         Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  meeting      Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  supersededBy Fact?    @relation("FactSupersede", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes   Fact[]   @relation("FactSupersede")

  @@index([userId])
  @@index([dealId])
  @@index([meetingId])
}
